# Pi Webcam Configuration
# Copy to pi-webcam.env and adjust values

# Data storage
PI_WEBCAM_DATA_DIR=/data/pi_webcam
PI_WEBCAM_DB_PATH=/data/pi_webcam/pi_webcam.db

# Capture settings
# Frames per second to save (0.5 = one frame every 2s, 1 = one per second)
PI_WEBCAM_CAPTURE_FPS=0.5
PI_WEBCAM_RTSP_URL=rtsp://localhost:8554/cam
PI_WEBCAM_JPEG_QUALITY=3

# Thumbnail settings
PI_WEBCAM_THUMB_WIDTH=320
PI_WEBCAM_THUMB_HEIGHT=180

# Retention settings
PI_WEBCAM_RETENTION_DAYS=14
PI_WEBCAM_RETENTION_CHECK_MINUTES=15
PI_WEBCAM_DISK_WATERMARK_MB=5120

# Web server
PI_WEBCAM_HOST=0.0.0.0
PI_WEBCAM_PORT=8080

# Optional basic auth (leave empty to disable)
PI_WEBCAM_AUTH_USERNAME=
PI_WEBCAM_AUTH_PASSWORD=

# MediaMTX URLs (for frontend)
PI_WEBCAM_WEBRTC_URL=http://localhost:8889/cam
PI_WEBCAM_HLS_URL=http://localhost:8888/cam
